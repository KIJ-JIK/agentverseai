# ──────────────────────────────────────────────────────────────────────────────
# DevFlow AI — Environment Configuration
# Copy this file to .env and fill in your actual API keys.
# ──────────────────────────────────────────────────────────────────────────────

# ── AI/ML API (High-Reasoning Agents: Architect, Reviewer, Release Manager) ──
AIML_API_KEY=your-aiml-api-key-here
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL=meta-llama/Llama-3-70b-instruct

# ── Featherless AI (Code-Gen Agents: Frontend Dev, Backend Dev, QA, Tech Writer) ──
FEATHERLESS_API_KEY=your-featherless-api-key-here
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# ── Band API (Multi-Agent Coordination Bus) ──
BAND_BASE_URL=https://api.band.ai/v1
BAND_ROOM_ID=your-room-id-here

# Agent API Keys
BAND_API_KEY_ARCHITECT=your-architect-key-here
BAND_API_KEY_FRONTEND=your-frontend-key-here
BAND_API_KEY_BACKEND=your-backend-key-here
BAND_API_KEY_REVIEWER=your-reviewer-key-here
BAND_API_KEY_QA_TESTER=your-qa-key-here
BAND_API_KEY_TECH_WRITER=your-techwriter-key-here
BAND_API_KEY_RELEASE_MANAGER=your-releasemanager-key-here

# ── Neon Database (PostgreSQL persistence for session history) ──
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ── Supabase (Authentication — Vercel frontend sends JWTs verified here) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ── Render (Deployment Automation) ──
RENDER_API_KEY=your-render-api-key-here

# ── Development Settings ──
# Set to True to skip real API calls (uses mock responses for local testing)
MOCK_MODE=True
